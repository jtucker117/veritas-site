# Copy these into Railway → your service → Variables (do NOT commit real values)

# Claude (Anthropic) API key — from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Gmail / Google Workspace sending account
# GMAIL_USER is the address that SENDS the lead emails (e.g. info@veritasgrouptx.com)
# GMAIL_APP_PASSWORD is a 16-char "App Password" from Google (NOT your login password).
#   Create at: Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=info@veritasgrouptx.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Where lead summaries are emailed (defaults to info@veritasgrouptx.com)
LEAD_TO=info@veritasgrouptx.com
